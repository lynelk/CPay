# CPay Environment Variables
# Copy this file to .env and fill in the actual values.
# NEVER commit the .env file to version control.

# Database
DB_URL=jdbc:mysql://localhost:3306/cpayadmin
DB_USERNAME=
DB_PASSWORD=

# Email (SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# Lock file directory
LOCK_FILE_DIRECTORY=/opt/cpayadmin/locks/

# MTN MoMo API credentials (loaded from DB settings at runtime)
MTN_COLLECTIONS_USER=
MTN_COLLECTIONS_KEY=
MTN_COLLECTIONS_SUBSCRIPTION=
MTN_DISBURSEMENTS_USER=
MTN_DISBURSEMENTS_KEY=
MTN_DISBURSEMENTS_SUBSCRIPTION=

# Airtel Money OpenAPI credentials (loaded from DB settings at runtime)
AIRTEL_COLLECTIONS_USER=
AIRTEL_COLLECTIONS_KEY=
AIRTEL_DISBURSEMENTS_USER=
AIRTEL_DISBURSEMENTS_KEY=
AIRTEL_DISBURSEMENTS_SUBSCRIPTION=

# Safaricom Daraja API credentials (loaded from DB settings at runtime)
SAFARICOM_CONSUMER_KEY=
SAFARICOM_CONSUMER_SECRET=

# Gateway state: SANDBOX or PRODUCTION
GATEWAY_STATE=SANDBOX
